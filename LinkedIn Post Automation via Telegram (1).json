    {
      "parameters": {
        "jsCode": "// Parse AI response and combine with message data\nconst aiResponse = $input.first().json.output;\nconst messageData = $('Extract Message Data1').first().json;\n\nlet parsedIntent;\ntry {\n  const jsonMatch = aiResponse.match(/\\{[^}]+\\}/);\n  parsedIntent = jsonMatch ? JSON.parse(jsonMatch[0]) : JSON.parse(aiResponse);\n} catch (e) {\n  parsedIntent = {\n    needsContent: true,\n    needsImage: false,\n    topic: messageData.userText\n  };\n}\n\nreturn {\n  json: {\n    chatId: messageData.chatId,\n    userText: messageData.userText,\n    hasPhoto: messageData.hasPhoto,\n    photoFileId: messageData.photoFileId,\n    needsContent: parsedIntent.needsContent,\n    needsImage: parsedIntent.needsImage && !messageData.hasPhoto,\n    topic: parsedIntent.topic || messageData.userText\n  }\n};"
      },
