    {
      "parameters": {
        "jsCode": "// Prepare data for LinkedIn posting\nconst items = $input.all();\nconst intentData = $('Parse Intent1').first().json;\n\nlet postText = intentData.userText;\nlet imageData = null;\nlet hasImage = false;\n\n// Extract generated content from Gemini response\nfor (const item of items) {\n  if (item.json.content && item.json.content.parts && item.json.content.parts[0]) {\n    postText = item.json.content.parts[1].text;\n  }\n  // Check for binary image data\n  if (item.binary && item.binary.data) {\n    imageData = item.binary.data;\n    hasImage = true;\n  }\n}\n\nreturn {\n  json: {\n    postText: postText,\n    hasImage: hasImage,\n    chatId: intentData.chatId\n  },\n  binary: imageData ? { data: imageData } : {}\n};"
      },
