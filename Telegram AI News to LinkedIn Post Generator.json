    {
      "parameters": {
        "jsCode": "// n8n Code Node: Extract AI trending topics from RSS feed XML\n\n// Get the input data (XML string)\nconst xmlData = $input.first().json.html || $input.first().json.data || '';\n\nfunction extractTagContent(item, tag) {\n  const regex = new RegExp(`<${tag}[^>]*>([\\\\s\\\\S]*?)<\\\\/${tag}>`, 'i');\n  const match = item.match(regex);\n  return match ? match[1].replace(/<!\\[CDATA\\[|\\]\\]>/g, '').trim() : null;\n}\n\n// Split into <item> blocks\nconst items = xmlData.split(/<\\/item>/i).filter(i => i.includes('<item>'));\n\nconst results = items.map((item) => {\n  const title = extractTagContent(item, 'title');\n  const url = extractTagContent(item, 'link');\n  const source = 'TechCrunch';\n  const publish_date = extractTagContent(item, 'pubDate');\n  const summary = extractTagContent(item, 'description');\n  \n  // Optional: relevance_score based on AI keyword frequency\n  const aiMentions = (item.match(/AI/gi) || []).length;\n  const relevance_score = Math.min(1, aiMentions / 3).toFixed(2); // normalize between 0–1\n\n  return {\n    json: {\n      title,\n      url,\n      source,\n      publish_date,\n      summary,\n      relevance_score,\n    }\n  };\n});\n\nreturn results;\n"
      },
