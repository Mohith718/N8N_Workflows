    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst chatId = items[0].json.chat_id;\n\nconst successCount = items.filter(item => item.json.status === 'success').length;\nconst failedCount = items.filter(item => item.json.status === 'failed').length;\n\nlet message = `✅ *LinkedIn Posts Generated!*\\n\\n`;\nmessage += `📊 *Summary:*\\n`;\nmessage += `✓ Successful: ${successCount}\\n`;\n\nif (failedCount > 0) {\n  message += `✗ Failed: ${failedCount}\\n`;\n}\n\nmessage += `\\n📝 *Generated Posts:*\\n\\n`;\n\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i].json;\n  if (item.status === 'success') {\n    message += `${i + 1}. *${item.topic}*\\n`;\n    message += `   Source: ${item.source}\\n`;\n    message += `   🔗 ${item.article_link}\\n\\n`;\n  }\n}\n\nmessage += `\\n💾 All posts have been saved to Google Sheets!`;\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    message: message,\n    parse_mode: 'Markdown'\n  }\n}];"
      },
