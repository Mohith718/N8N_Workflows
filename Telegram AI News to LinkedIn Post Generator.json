      "parameters": {
        "jsCode": "// Get input value safely\nlet raw = $input.first().json.data || $input.first().json.text || JSON.stringify($input.first().json);\n\n// Step 1: Remove unwanted escape characters like \\\"\nraw = raw.replace(/\\\\\"/g, '\"');\n\n// Step 2: Clean leading/trailing quotes if present\nraw = raw.replace(/^\"|\"$/g, '');\n\n// Step 3: Try to parse JSON properly\nlet parsed = {};\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  // Fallback to regex if JSON.parse fails\n  parsed.topic = raw.match(/\"topic\":\"(.*?)\"/)?.[1] || '';\n  parsed.article_link = raw.match(/\"article_link\":\"(.*?)\"/)?.[1] || '';\n  parsed.date_posted = raw.match(/\"date_posted\":\"(.*?)\"/)?.[1] || '';\n  parsed.post_content = raw.match(/\"post_content\":\"([\\s\\S]*?)\"}/)?.[1] || '';\n}\n\n// Step 4: Build clean structured output\nreturn [\n  {\n    json: {\n      topic: parsed.topic || '',\n      title: parsed.topic || '',\n      date_posted: parsed.date_posted || '',\n      post_content: parsed.post_content || '',\n      source: parsed.article_link || ''\n    }\n  }\n];\n"
      },
