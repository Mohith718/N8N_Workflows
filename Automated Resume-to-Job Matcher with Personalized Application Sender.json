    {
      "parameters": {
        "jsCode": "// Generate sample job listings based on candidate's profile\nconst interestedDomain = $('Workflow Configuration').first().json.interestedDomain;\nconst candidateSkills = $('Parse Resume Agent').first().json.output.skills || [];\n\n// Sample companies and locations\nconst companies = [\n  'Google', 'Microsoft', 'Amazon', 'Meta', 'Apple', 'Netflix', 'Salesforce',\n  'IBM', 'Oracle', 'Adobe', 'Uber', 'Airbnb', 'LinkedIn', 'Twitter', 'Spotify',\n  'Stripe', 'Shopify', 'Zoom', 'Slack', 'Dropbox'\n];\n\nconst locations = [\n  'San Francisco, CA', 'New York, NY', 'Seattle, WA', 'Austin, TX',\n  'Boston, MA', 'Chicago, IL', 'Los Angeles, CA', 'Denver, CO',\n  'Atlanta, GA', 'Remote', 'Hybrid - Bay Area', 'Remote (US)'\n];\n\n// Generate job listings\nconst jobListings = [];\nconst numJobs = 18;\n\nfor (let i = 0; i < numJobs; i++) {\n  const company = companies[i % companies.length];\n  const location = locations[i % locations.length];\n  \n  // Select 3-5 relevant skills for this job\n  const numSkills = Math.min(3 + Math.floor(Math.random() * 3), candidateSkills.length);\n  const jobSkills = [];\n  const usedIndices = new Set();\n  \n  while (jobSkills.length < numSkills && usedIndices.size < candidateSkills.length) {\n    const idx = Math.floor(Math.random() * candidateSkills.length);\n    if (!usedIndices.has(idx)) {\n      usedIndices.add(idx);\n      jobSkills.push(candidateSkills[idx]);\n    }\n  }\n  \n  const skillsList = jobSkills.join(', ');\n  \n  // Generate job description\n  const description = `We are seeking a talented ${interestedDomain} to join our team at ${company}. \n\nKey Responsibilities:\n- Analyze complex datasets to drive business decisions\n- Create insightful visualizations and reports\n- Collaborate with cross-functional teams\n- Develop data models and analytical frameworks\n\nRequired Skills:\n${jobSkills.map(skill => `- ${skill}`).join('\\n')}\n\nWe offer competitive compensation, excellent benefits, and opportunities for growth.`;\n  \n  // Generate job title variations\n  const titleVariations = [\n    `${interestedDomain}`,\n    `Senior ${interestedDomain}`,\n    `${interestedDomain} - ${company}`,\n    `Junior ${interestedDomain}`,\n    `${interestedDomain} Specialist`\n  ];\n  \n  const jobTitle = titleVariations[i % titleVariations.length];\n  \n  jobListings.push({\n    jobTitle: jobTitle,\n    company: company,\n    location: location,\n    description: description,\n    applyUrl: `https://careers.${company.toLowerCase().replace(/\\s+/g, '')}.com/jobs/${i + 1000}`,\n    hrEmail: `hr.recruiting@${company.toLowerCase().replace(/\\s+/g, '')}.com`\n  });\n}\n\n// Return the job listings\nreturn jobListings.map(job => ({ json: job }));"
      },
