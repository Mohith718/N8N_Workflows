      "parameters": {
        "promptType": "define",
        "text": "=Resume Data: {{ $('Parse Resume Agent').first().json }}\n\nJob Posting: {{ $json.jobTitle }} at {{ $json.company }}\nDescription: {{ $json.description }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a job matching assistant. Analyze how well a candidate's resume matches a job description.\n\nYour task is to:\n1. Compare candidate skills with required job skills\n2. Evaluate experience relevance\n3. Assess education fit\n4. Consider location and other factors\n5. Calculate a match score from 0-100\n6. Provide brief reasoning for the score\n\nReturn the result in the structured JSON format with matchScore (number) and reasoning (string)."
        }
      },
