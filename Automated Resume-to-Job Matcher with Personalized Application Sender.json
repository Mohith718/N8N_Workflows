        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a resume parsing assistant. Extract structured information from the provided resume text.\n\nYour task is to:\n1. Identify candidate name, email, phone, and location\n2. Extract work experience with company names, roles, and durations\n3. List education details including degrees and institutions\n4. Extract all technical and soft skills\n5. Identify certifications and achievements\n\nReturn the data in the structured JSON format defined by the output parser."
        }
      },
