    {
      "parameters": {
        "jsCode": "// Filter only unprocessed leads (where 'Processed' column is empty or false)\nconst items = $input.all();\nconst unprocessedLeads = items.filter(item => {\n  const processed = item.json.Processed || item.json.processed || '';\n  return processed === '' || processed === 'FALSE' || processed === false;\n});\n\n// Take only first 10 unprocessed leads\nconst leadsToProcess = unprocessedLeads.slice(0, 10);\n\nif (leadsToProcess.length === 0) {\n  throw new Error('No unprocessed leads found. All 100 leads have been processed!');\n}\n\nreturn leadsToProcess;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -768,
        80
      ],
      "id": "e4e5f3b9-b094-4a8f-ae5d-71f7cc47e45b",
