    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "models/gemini-2.0-flash-exp",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "content": "=You are an expert SMS copywriter for B2B outreach.\n\n## CONTEXT\nRecipient Name: {{ $json.firstName }}\nCompany: {{ $json.companyName || 'their business' }}\nPhone: {{ $json.phone }}\n\n## YOUR TASK\nWrite a professional SMS message about AI automation services that can 10X business growth.\n\n## SMS REQUIREMENTS\n- Maximum length: 160 characters (strict)\n- Personalize with first name\n- Mention one key benefit (time savings or revenue growth)\n- Include clear call-to-action\n- Professional but conversational tone\n\n## STRUCTURE\n1. Greeting with name\n2. One sentence value proposition\n3. Soft CTA (reply or call)\n\n## RULES\n- NO emojis\n- NO links (SMS will include reply instructions)\n- NO multiple sentences per point\n- Use simple, direct language\n- Sound human, not robotic\n\n## EXAMPLE STYLE\nHi [Name], AI automation helped businesses like yours achieve 10X growth. Free 15-min call? Reply YES.\n\nNow write the SMS. Output ONLY the message text, nothing else."
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "temperature": 0.7
        }
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.1,
      "position": [
        -112,
        192
      ],
      "id": "f7af0da4-1fa6-4d25-bf4a-f0ce313b5cbe",
      "name": "Generate Personalized SMS",
      "credentials": {
        "googlePalmApi": {
          "id": "SgSXLURnz7IswDf0",
          "name": "Google Gemini(PaLM) Api account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Extract SMS content from AI response\nconst response = $input.first().json;\nlet smsText = response.content?.parts?.[0]?.text || response.text || '';\n\nif (!smsText) {\n  throw new Error('AI did not generate SMS content');\n}\n\n// Clean the SMS text\nsmsText = smsText.trim();\n\n// Ensure it's under 160 characters\nif (smsText.length > 160) {\n  smsText = smsText.substring(0, 157) + '...';\n}\n\n// Get lead data from previous node\nconst leadData = $('Normalize Lead Data').first().json;\n\n// Format phone number for Twilio (ensure it has country code)\nlet phoneNumber = leadData.phone.toString().replace(/\\D/g, '');\nif (!phoneNumber.startsWith('1') && phoneNumber.length === 10) {\n  phoneNumber = '1' + phoneNumber; // Add US country code if missing\n}\nphoneNumber = '+' + phoneNumber;\n\nreturn [{\n  json: {\n    message: smsText,\n    to: phoneNumber,\n    firstName: leadData.firstName,\n    rowNumber: leadData.rowNumber\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
