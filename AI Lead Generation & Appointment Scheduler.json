      "parameters": {
        "jsCode": "// Wait for all branches to complete and merge results\nconst emailResults = $input.all().filter(item => item.json.ContactMethod === 'Email');\nconst smsResults = $input.all().filter(item => item.json.ContactMethod === 'SMS');\n\nconst totalProcessed = emailResults.length + smsResults.length;\nconst emailCount = emailResults.length;\nconst smsCount = smsResults.length;\n\nreturn [{\n  json: {\n    date: new Date().toISOString().split('T')[0],\n    totalProcessed,\n    emailsSent: emailCount,\n    smsSent: smsCount,\n    message: `Successfully processed ${totalProcessed} leads: ${emailCount} emails and ${smsCount} SMS messages sent.`\n  }\n}];"
      },
